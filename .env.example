# Plantilla de variables de entorno. En Railway, configúralas como variables
# del servicio (no como archivo .env). Localmente, copia a .env.

# Claves de Alpaca (Paper Trading recomendado para empezar)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# true = cuenta Alpaca Paper (sin dinero real); false = cuenta real
ALPACA_PAPER=true
# Feed de datos de mercado: iex (gratuito) o sip (de pago)
ALPACA_DATA_FEED=iex

# Tipo de cambio EUR->USD (USD por 1 EUR). Si falta, usa capital.fallback_fx_rate
EURUSD_RATE=1.08

# PostgreSQL de Railway (opcional). Si no se define, el bot usa solo logs JSONL.
DATABASE_URL=
